#!/usr/bin/env bash
# ca_import verification script — generated by Ansible
# Run after the role to confirm the CA is trusted by each configured store.
set -euo pipefail

CA_URL="{{ ca_import_fetch_url if ca_import_fetch_url != '' else 'N/A' }}"
CA_NAME="{{ ca_import_name }}"
CA_LABEL="{{ ca_import_label }}"
ERRORS=0

green()  { printf '\033[0;32m✓ %s\033[0m\n' "$*"; }
red()    { printf '\033[0;31m✗ %s\033[0m\n' "$*"; ERRORS=$((ERRORS+1)); }
yellow() { printf '\033[0;33m- %s\033[0m\n' "$*"; }

echo "=== CA Trust Verification: ${CA_LABEL} ==="
echo

# 1. System trust store
echo "--- System trust store ---"
if command -v openssl &>/dev/null; then
  if openssl verify -CAfile \
      "$(openssl version -d 2>/dev/null | awk -F'"' '{print $2}')/cert.pem" \
      /dev/null 2>/dev/null || \
     openssl s_client -connect /dev/null 2>/dev/null; then
    true
  fi

  # Try to connect to the PKI server and verify it's trusted
  {% if ca_import_fetch_url != '' %}
  PKI_HOST=$(echo "${CA_URL}" | sed 's|https\?://||;s|/.*||;s|:.*||')
  PKI_PORT=$(echo "${CA_URL}" | grep -oP ':\K[0-9]+' || echo "443")
  if openssl s_client \
      -connect "${PKI_HOST}:${PKI_PORT}" \
      -verify_return_error \
      </dev/null 2>/dev/null | grep -q "Verify return code: 0"; then
    green "openssl: PKI server certificate is trusted"
  else
    yellow "openssl: could not verify PKI server (may be HTTP or unreachable)"
  fi
  {% endif %}

  # Check CA is in trust anchors
  if openssl verify \
      /usr/local/share/ca-certificates/${CA_NAME}.crt 2>/dev/null | grep -q OK; then
    green "system trust store (Debian): CA found and valid"
  elif openssl verify \
      /etc/pki/ca-trust/source/anchors/${CA_NAME}.pem 2>/dev/null | grep -q OK; then
    green "system trust store (RedHat): CA found and valid"
  else
    yellow "system trust store: could not directly verify (may still be trusted)"
  fi
else
  yellow "openssl not found — skipping system store check"
fi

echo

# 2. curl
echo "--- curl ---"
{% if ca_import_curl %}
if command -v curl &>/dev/null && [ -f /etc/ssl/certs/pypki-bundle.pem ]; then
  {% if ca_import_fetch_url != '' %}
  if curl --silent --fail --cacert /etc/ssl/certs/pypki-bundle.pem \
      "${CA_URL}" -o /dev/null 2>/dev/null; then
    green "curl: CA bundle trusts PKI server"
  else
    yellow "curl: could not reach PKI server — bundle may still be correct"
  fi
  {% endif %}
  if grep -q "BEGIN CERTIFICATE" /etc/ssl/certs/pypki-bundle.pem; then
    green "curl: pypki-bundle.pem exists and contains certificates"
  else
    red "curl: pypki-bundle.pem is missing or empty"
  fi
else
  red "curl: /etc/ssl/certs/pypki-bundle.pem not found"
fi
{% else %}
yellow "curl store not configured (ca_import_curl: false)"
{% endif %}

echo

# 3. Java
echo "--- Java ---"
{% if ca_import_java %}
if command -v keytool &>/dev/null; then
  CACERTS=$(java -XshowSettings:all -version 2>&1 \
    | grep 'java.home' | awk '{print $NF}')/lib/security/cacerts
  if keytool -list \
      -alias "${CA_NAME}" \
      -keystore "${CACERTS}" \
      -storepass "{{ ca_import_java_storepass }}" \
      -noprompt &>/dev/null; then
    green "Java cacerts: alias '${CA_NAME}' found"
  else
    red "Java cacerts: alias '${CA_NAME}' not found in ${CACERTS}"
  fi
else
  yellow "keytool not found — skipping Java check"
fi
{% else %}
yellow "Java store not configured (ca_import_java: false)"
{% endif %}

echo

# 4. Python certifi
echo "--- Python certifi ---"
{% if ca_import_python %}
CERTIFI_PATH=$({{ ca_import_python_bin }} -c \
  "import certifi; print(certifi.where())" 2>/dev/null || true)
if [ -n "${CERTIFI_PATH}" ]; then
  if grep -q "PYPKI CA: ${CA_NAME}" "${CERTIFI_PATH}"; then
    green "Python certifi: CA found in ${CERTIFI_PATH}"
  else
    red "Python certifi: CA not found in ${CERTIFI_PATH}"
  fi
else
  yellow "certifi not installed — skipping Python check"
fi
{% else %}
yellow "Python certifi not configured (ca_import_python: false)"
{% endif %}

echo

# 5. NSS
echo "--- Mozilla NSS ---"
{% if ca_import_nss %}
if command -v certutil &>/dev/null; then
  NSS_FOUND=0
  while IFS= read -r -d '' dbdir; do
    if certutil -L -d "sql:${dbdir}" 2>/dev/null | grep -q "${CA_LABEL}"; then
      green "NSS: CA found in ${dbdir}"
      NSS_FOUND=1
    fi
  done < <(find /root /home /etc/pki/nssdb \
    -name "cert9.db" -printf '%h\0' 2>/dev/null)
  [ "${NSS_FOUND}" -eq 0 ] && yellow "NSS: no databases checked or CA not found"
else
  yellow "certutil not found — skipping NSS check"
fi
{% else %}
yellow "NSS not configured (ca_import_nss: false)"
{% endif %}

echo
echo "=== Summary ==="
if [ "${ERRORS}" -eq 0 ]; then
  green "All configured trust stores verified successfully."
  exit 0
else
  red "${ERRORS} verification failure(s) detected."
  exit 1
fi
